VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings → API → anon / publishable key (restart dev server after changes)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Follow-up email API (backend). Use http://localhost:3001 or leave empty to use Vite proxy (/api).
VITE_API_URL=http://localhost:3001

# Prisma + Supabase Postgres
# Transaction pooler (runtime / Prisma Client via adapter)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler or direct (Prisma CLI migrations)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"
